#!/bin/bash

# Launch the Whiptail menu

if [ -f "/run/live/medium/live/filesystem.squashfs" ]; then
 CHOICE=$(whiptail --title "RetroDebian Menu" \
                 --menu "Select an option to launch:" 15 60 6 \
                 "1" "Retroarch" \
                 "2" "EmulationStation" \
                 "3" "Configurator" \
                 "4" "Network" \
                 "5" "Poweroff" \
                 "6" "Installer" \
                 "S" "Shell" 3>&1 1>&2 2>&3)

else
 #not a live system, remove installer
 CHOICE=$(whiptail --title "RetroDebian Menu" \
                 --menu "Select an option to launch:" 15 60 6 \
                 "1" "Retroarch" \
                 "2" "EmulationStation" \
                 "3" "Configurator" \
                 "4" "Network" \
                 "5" "Poweroff" \
                 "S" "Shell" 3>&1 1>&2 2>&3)
fi

# Handle the user's exit status
EXIT_STATUS=$?
if [ $EXIT_STATUS -ne 0 ]; then
    echo "Menu cancelled or closed."
    exit 1
fi

# Execute actions based on the selection
case "$CHOICE" in
    "1")
        echo "Launching Retroarch..."
        retroarch && menu
        ;;
    "2")
        echo "Launching EmulationStation..."
        myesde && menu
        ;;
    "3")
        echo "Configurator..."
        sudo configurator && menu
        ;;
    "4")
        echo "Network..."
        nmtui && menu
        ;;
    "5")
        echo "Power off..."
        systemctl poweroff
        ;;
    "6")
        echo "Launching Installer..."
        sudo format_newinstallgui && menu
        ;;
    "S"|"s")
        echo "Exit"
        exit 0
        ;;
esac
