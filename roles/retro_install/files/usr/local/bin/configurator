#!/bin/sh

rm /home/arcade/.config/retroarch/retroarch.cfg

CHOICE0=$(whiptail --title "RetroDebian Configurator" \
                   --menu "Select your frontend:" 15 60 6 \
                   "1" "Retroarch" \
                   "2" "ES-DE" 3>&1 1>&2 2>&3)

if [ $CHOICE0 -eq 1 ]; then #retroarch frontend
 echo "Now retroarch is the default launcher"
 sed -i 's,myesde,retroarch,g' /etc/profile.d/99-launcher.sh
fi

if [ $CHOICE0 -eq 2 ]; then #ES-DE frontend
 echo "Now ES-DE is the default launcher"
 sed -i 's,retroarch,myesde,g' /etc/profile.d/99-launcher.sh
fi

CHOICE1=$(whiptail --title "RetroDebian Configurator" \
                   --menu "Select your monitor:" 15 60 6 \
                   "1" "CRT" \
                   "2" "LCD" 3>&1 1>&2 2>&3)

if [ $CHOICE1 -eq 2 ]; then #LCD monitor
 echo "LCD monitor, nothing else to do"
 sed -i 's,crt_switch_resolution =.*,crt_switch_resolution = "0",g' /etc/retroarch.cfg
 sed -i '24s,monitor.*,monitor lcd,g' /etc/switchres.ini
 sed -i '41s,lcd_range.*,lcd_range 50-61,g' /etc/switchres.ini
 sed -i 's,video_scale_integer =.*,video_scale_integer = "true",g' /etc/retroarch.cfg
 sed -i 's,GRUB_CMDLINE_LINUX_DEFAULT=.*,GRUB_CMDLINE_LINUX_DEFAULT="",g' /etc/default/grub
 update-grub
 exit
fi

sed -i 's,crt_switch_resolution =.*,crt_switch_resolution = "4",g' /etc/retroarch.cfg
sed -i '24s,monitor.*,monitor generic_15,g' /etc/switchres.ini
sed -i 's,video_scale_integer =.*,video_scale_integer = "false",g' /etc/retroarch.cfg

CHOICE2=$(whiptail --title "RetroDebian Configurator" \
                   --menu "Select your graphics card:" 15 60 6 \
                   "1" "ATI" \
                   "2" "Generic" 3>&1 1>&2 2>&3)

if [ $CHOICE2 -eq 1 ]; then #ati card
 sed -i 's,crt_switch_resolution_super.*,crt_switch_resolution_super = "1",g' /etc/retroarch.cfg
 sed -i 's,dotclock_min.*,dotclock_min 0,g' /etc/switchres.ini

 CHOICE3=$(whiptail --title "RetroDebian Configurator" \
                    --menu "Select system resolution:" 15 60 6 \
                    "1" "240p" \
                    "2" "480i" 3>&1 1>&2 2>&3)

 if [ $CHOICE3 -eq 1 ]; then #ES-DE 240p
  echo "ATI 240p native"
  sed -i 's,GRUB_CMDLINE_LINUX_DEFAULT=.*,GRUB_CMDLINE_LINUX_DEFAULT="video=320x240S",g' /etc/default/grub
  update-grub
 else
  echo "ATI 480i native"
  sed -i 's,GRUB_CMDLINE_LINUX_DEFAULT=.*,GRUB_CMDLINE_LINUX_DEFAULT="video=640x480iS",g' /etc/default/grub
  update-grub
 fi
fi

if [ $CHOICE2 -eq 2 ]; then #non ati card
 echo "super resolution"
 sed -i 's,crt_switch_resolution_super.*,crt_switch_resolution_super = "2560",g' /etc/retroarch.cfg
 sed -i 's,dotclock_min.*,dotclock_min 25.0,g' /etc/switchres.ini
 sed -i 's,GRUB_CMDLINE_LINUX_DEFAULT=.*,GRUB_CMDLINE_LINUX_DEFAULT="video=1280x480iS",g' /etc/default/grub
 update-grub
fi
